# Copy this file to .env (same folder as manage.py) and fill in real values.
# python-dotenv loads this automatically when you run the server — no need
# to `export` anything manually.
#
# The defaults below are safe for LOCAL TESTING (127.0.0.1/localhost).
# Before you deploy to a real server, change the 3 lines marked
# "CHANGE BEFORE DEPLOYING" further down.

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_FORCE_HTTPS=False

# --- Gmail SMTP (so OTP codes are actually emailed to users) ---------------
# 1. Turn on 2-Step Verification on your Gmail account:
#    https://myaccount.google.com/security
# 2. Create an "App Password":
#    https://myaccount.google.com/apppasswords
#    (Choose app: "Mail", device: "Other" -> name it "LykoonAdds")
#    Google gives you a 16-character password like: abcd efgh ijkl mnop
#    Use it below WITHOUT spaces. This is NOT your normal Gmail password.
# 3. Fill in your own Gmail address and that app password here:
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USER=youraddress@gmail.com
DJANGO_EMAIL_PASSWORD=abcdefghijklmnop

# --- CHANGE BEFORE DEPLOYING TO A REAL SERVER ------------------------------
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DJANGO_FORCE_HTTPS=True
